rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Academic Resources (Course Materials)
    match /academic_resources/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == "clainyemblo@gmail.com";
    }

    // Student Submissions
    match /submissions/{studentId}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == studentId || request.auth.token.email == "clainyemblo@gmail.com");
      allow write: if request.auth != null && request.auth.uid == studentId;
      allow delete: if request.auth != null && request.auth.token.email == "clainyemblo@gmail.com";
    }

    // General Submissions (Admin view)
    match /submissions/{allPaths=**} {
      allow read: if request.auth != null && request.auth.token.email == "clainyemblo@gmail.com";
    }

    // Student Documents (Admission letters, receipts, etc.)
    match /student_documents/{studentId}/{allPaths=**} {
      allow read: if request.auth != null && (
        request.auth.uid == studentId || 
        request.auth.token.email == "clainyemblo@gmail.com"
      );
      allow write: if request.auth != null && request.auth.uid == studentId && request.resource.size < 10 * 1024 * 1024;
      allow delete: if request.auth != null && (
        request.auth.uid == studentId || 
        request.auth.token.email == "clainyemblo@gmail.com"
      );
    }

    // Profile Images
    match /profile_images/{studentId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == studentId && request.resource.size < 5 * 1024 * 1024;
    }

    // Official School Documents (Templates, Prospectus, etc.)
    match /school_documents/{allPaths=**} {
      allow read: if request.auth != null;
      allow write, delete: if request.auth != null && request.auth.token.email == "clainyemblo@gmail.com";
    }
  }
}
