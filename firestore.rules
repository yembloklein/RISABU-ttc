
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Risabu Connect ERP Security Rules
     *
     * Philosophy:
     * - Super Admin: Strictly limited to clainyemblo@gmail.com.
     * - Authorization Independence: Role-based access controlled via dedicated collections.
     */

    // --- Helper Functions ---

    /** @description Checks if a user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user is the designated super admin. */
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == "clainyemblo@gmail.com";
    }

    /** @description Checks if the user exists in the admin role collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) && isSuperAdmin();
    }

    /** @description Checks if the user exists in the staff role collection. */
    function isStaff() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_staff/$(request.auth.uid));
    }

    /** @description Convenience check for any internal/management role. */
    function isInternal() {
      return isAdmin() || isStaff();
    }

    /** @description Checks if the current user's UID matches the provided UID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Validates that the recordedBy field in the document matches the actor. */
    function isResourceRecorder(data) {
      return isSignedIn() && data.recordedByUserFirebaseUid == request.auth.uid;
    }

    /** @description Validates that the student field in the document matches the actor. */
    function isResourceStudent(data) {
      return isSignedIn() && data.studentFirebaseUid == request.auth.uid;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isInternal();
      allow list: if isInternal();
      allow create: if (isOwner(userId) && request.resource.data.firebaseUid == userId) || isAdmin();
      allow update: if (isOwner(userId) || isAdmin()) && (isAdmin() || request.resource.data.firebaseUid == resource.data.firebaseUid);
      allow delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSuperAdmin() && request.auth.uid == userId;
      allow update, delete: if isSuperAdmin();
    }

    match /roles_staff/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() || isAdmin(); 
      allow update, delete: if isAdmin();
    }

    match /programs/{programId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /students/{studentId} {
      allow get: if isInternal() || (isSignedIn() && resource.data.firebaseUid == request.auth.uid);
      allow list: if isInternal();
      allow create, update: if isInternal();
      allow delete: if isAdmin();
    }

    match /enrollments/{enrollmentId} {
      allow get, list: if isInternal() || isResourceStudent(resource.data);
      allow create, update: if isInternal();
      allow delete: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow get, list: if isInternal() || isResourceStudent(resource.data);
      allow create: if isInternal() && request.resource.data.recordedByUserFirebaseUid == request.auth.uid;
      allow update: if isInternal() && (isAdmin() || isResourceRecorder(resource.data));
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow get, list: if isInternal() || isResourceStudent(resource.data);
      allow create: if isInternal() && request.resource.data.recordedByUserFirebaseUid == request.auth.uid;
      allow update: if isInternal() && (isAdmin() || isResourceRecorder(resource.data));
      allow delete: if isAdmin();
    }

    match /expenseCategories/{categoryId} {
      allow get, list: if isInternal();
      allow create, update: if isInternal();
      allow delete: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow get, list: if isInternal();
      allow create: if isInternal() && request.resource.data.recordedByUserFirebaseUid == request.auth.uid;
      allow update: if (isAdmin() || (isInternal() && isResourceRecorder(resource.data))) && request.resource.data.recordedByUserFirebaseUid == resource.data.recordedByUserFirebaseUid;
      allow delete: if isAdmin();
    }
  }
}
